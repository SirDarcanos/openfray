# ───────────────────────────────────────────────────────────────
# SECRETS — never commit these. Supabase keys, API keys, etc.
# ───────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local
local/

# ───────────────────────────────────────────────────────────────
# Dependencies
# ───────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ───────────────────────────────────────────────────────────────
# Build output
# ───────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
.vite/

# ───────────────────────────────────────────────────────────────
# Test / coverage
# ───────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ───────────────────────────────────────────────────────────────
# Logs & debug
# ───────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────────────────────────────────────────────────
# Editor / OS
# ───────────────────────────────────────────────────────────────
# Keep shared VS Code settings, but ignore machine-specific bits.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.swp

# ───────────────────────────────────────────────────────────────
# Supabase local dev (if you use the Supabase CLI later)
# ───────────────────────────────────────────────────────────────
supabase/.branches
supabase/.temp
supabase/.env

# ───────────────────────────────────────────────────────────────
# Local-only scratch (session notes, handoff docs) — never committed.
# ───────────────────────────────────────────────────────────────
local/

# ───────────────────────────────────────────────────────────────
# Misc
# ───────────────────────────────────────────────────────────────
*.tsbuildinfo
.cache/
.tmp/