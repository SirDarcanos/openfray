---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — OpenFray" description="Page not found. It probably wandered off the battle map.">
  <main class="hero">
    <h1>404</h1>
    <p class="tagline">
      <strong>Page not found.</strong> It probably wandered off the battle map — the link may be
      broken, or the page may have moved.
    </p>
    <a class="cta" href="/">Back to home →</a>
    <p class="disclaimer">
      Looking for the app? <a href="/console/">Open the console</a>.
    </p>
  </main>
</Layout>
