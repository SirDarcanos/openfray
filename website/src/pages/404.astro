---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — OpenFray" description="That page wandered off the battle map.">
  <main class="hero">
    <span class="badge">404</span>
    <h1>Page not found</h1>
    <p class="tagline">
      That page wandered off the battle map. The link may be broken, or the page may have moved.
    </p>
    <a class="cta" href="/">Back to home →</a>
    <p class="disclaimer">
      Looking for the app? <a href="/console/">Open the console</a>.
    </p>
  </main>
</Layout>
