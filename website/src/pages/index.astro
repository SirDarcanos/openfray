---
import Layout from '../layouts/Layout.astro';

const features = [
  { title: 'The state others forget', body: "Who has advantage on whom, who's debuffed, who's concentrating — the between-creature state other trackers drop on the floor." },
  { title: 'Monster resources, handled', body: 'Recharge abilities, legendary actions, Legendary Resistance, lair actions, concentration, and reactions — all tracked as you play.' },
  { title: 'One-tap group saves', body: "Roll a whole pack's save against a single effect at once, with resistances, immunities, and Evasion applied for you." },
  { title: 'Honest, transparent dice', body: 'Cryptographically random rolls with a clear, effect-aware log. No fudging, no “feels-fair” tampering — ever.' },
  { title: 'Build your own', body: 'Custom creatures and spells with a full stat-block editor, a reusable characters roster, and campaigns with house rules.' },
  { title: 'Free, and yours', body: 'Runs fully in your browser with no account. Sign in free with Discord or Google to save and sync across devices.' },
];
---

<Layout
  title="OpenFray — a DnD 5e combat console for DMs"
  description="OpenFray is a free, browser-based combat console for running DnD 5e encounters — initiative, monster resources, conditions, group saves, and honest dice. In alpha testing."
>
  <main class="hero">
    <span class="badge">Alpha Testing</span>

    <h1><span class="o">Open</span>Fray</h1>

    <p class="tagline">
      OpenFray is a free, browser-based <strong>combat console for running DnD&nbsp;5e</strong>
      encounters. It tracks initiative, monster resources, conditions, concentration, group saves,
      and honest dice in one fast, glanceable place — built for Dungeon Masters who need to keep
      hold of what's happening in a fight without losing the thread.
    </p>

    <a class="cta" href="/console/">Open the console →</a>

    <section class="features">
      {features.map((f) => (
        <div class="feature">
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))}
    </section>

    <p class="disclaimer">
      Compatible with fifth edition. Not affiliated with, endorsed, sponsored, or specifically
      approved by Wizards of the Coast LLC. Game reference content is used under CC-BY-4.0.
    </p>
  </main>
</Layout>
