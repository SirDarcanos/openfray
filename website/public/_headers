# Cloudflare Pages response headers. Applies to the whole deploy (marketing site
# at / and the app at /console). See https://developers.cloudflare.com/pages/configuration/headers/
#
# The CSP below is Report-Only: it logs violations to the browser console but blocks
# nothing. Once the deployed app shows no CSP violations (sign in, load the compendium,
# roll, cast), rename `Content-Security-Policy-Report-Only` to `Content-Security-Policy`.

# Security headers on every response.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://jhfjzzciubewzujafadj.supabase.co wss://jhfjzzciubewzujafadj.supabase.co https://cloudflareinsights.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'

# Content-hashed build assets never change under a given URL — cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
/console/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Bundled SRD data (fixed filenames, refreshed on rebuild) — cache a day.
/console/compendium/*
  Cache-Control: public, max-age=86400

# Brand assets.
/favicon.svg
  Cache-Control: public, max-age=604800
/og-image.png
  Cache-Control: public, max-age=604800
